# ── Required ──────────────────────────────────────────────────────────────────

# Telegram Bot API token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your personal Telegram user ID (from @userinfobot or @getmyid_bot)
ALLOWED_USER_ID=123456789

# ── Optional ──────────────────────────────────────────────────────────────────

# How often to poll the RSS feed in seconds (default: 60, matching feed TTL)
# POLL_INTERVAL=60

# Max number of individual notifications sent per polling round before summarising
# MAX_NOTIFICATIONS_PER_POLL=10

# Alert after this many consecutive RSS fetch failures
# RSS_FAIL_ALERT_THRESHOLD=3

# Path to the SQLite database file inside the container (default: data/keywords.db)
# DATABASE_PATH=data/keywords.db
